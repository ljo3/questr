# Copy to /etc/questr/questr.env on the box and fill in. Read by systemd.
# chmod 600 and own by root — it holds live credentials.

OPENROUTER_API_KEY=sk-or-v1-...

# Scoped IAM user with ONLY s3:PutObject on the bucket (create with
# infra/, or ask Claude to mint `questr-signer`).
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-west-3

PHOTO_BUCKET=photo-bucket-333886071196-eu-west-3-an

# Origins allowed to call the API (comma-separated, no trailing slash).
ALLOW_ORIGIN=https://questr.pages.dev,http://localhost:5173
