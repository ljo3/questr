[Unit]
Description=Questr collage API
After=network.target

[Service]
User=questr
WorkingDirectory=/opt/questr
EnvironmentFile=/etc/questr/questr.env
ExecStart=/opt/questr/.venv/bin/uvicorn server.app:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
